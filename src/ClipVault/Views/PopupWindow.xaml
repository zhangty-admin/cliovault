<Window x:Class="ClipVault.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ClipVault.Views"
        xmlns:models="clr-namespace:ClipVault.Models"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        ShowActivated="True"
        KeyDown="Window_KeyDown"
        Deactivated="Window_Deactivated"
        Height="500">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <!-- 外层边框 + 阴影 -->
    <Border Margin="8"
            Background="{DynamicResource BackgroundBrush}"
            CornerRadius="14"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30"
                              ShadowDepth="2"
                              Opacity="0.6"
                              Color="Black" />
        </Border.Effect>

        <Border.RenderTransform>
            <TranslateTransform x:Name="PopupTransform" Y="0" />
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ===== 顶部栏：搜索框 + 标签栏 + 清空（同一行） ===== -->
            <Grid Grid.Row="0" Margin="18,16,18,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 搜索框（固定宽度，行首） -->
                <Border Grid.Column="0"
                        Width="280"
                        Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Margin="0,0,14,0">
                    <Border.Resources>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Resources>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="🔍"
                                   FontSize="15"
                                   VerticalAlignment="Center"
                                   Margin="14,0,8,0"
                                   Opacity="0.5" />
                        <TextBox Grid.Column="1"
                                 x:Name="SearchBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 CaretBrush="{DynamicResource PrimaryTextBrush}"
                                 FontSize="15"
                                 Padding="0,9,12,9"
                                 VerticalContentAlignment="Center" />
                    </Grid>
                </Border>

                <!-- 标签栏（搜索框右侧，横向滚动） -->
                <ScrollViewer Grid.Column="1"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              PreviewMouseWheel="TagBarScroll_PreviewMouseWheel">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <!-- "历史"按钮：chip 样式，默认选中高亮 -->
                        <Border x:Name="AllTagChip"
                                Padding="12,6"
                                CornerRadius="6"
                                Cursor="Hand"
                                Margin="0,0,6,0"
                                Background="{DynamicResource AccentBrush}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                BorderThickness="1"
                                MouseLeftButtonUp="AllTag_Click">
                            <TextBlock Text="历史"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="White"
                                       VerticalAlignment="Center" />
                        </Border>

                        <!-- 新建分组按钮 -->
                        <Border x:Name="AddTagButton"
                                Padding="10,6"
                                CornerRadius="6"
                                Cursor="Hand"
                                Margin="0,0,6,0"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1,1,1,1"
                                MouseLeftButtonUp="AddTag_Click">
                            <TextBlock Text="＋"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       VerticalAlignment="Center" />
                        </Border>

                        <!-- 新建分组输入框（点击 + 后显示） -->
                        <Border x:Name="NewTagInputBox"
                                Padding="8,4"
                                CornerRadius="6"
                                Margin="0,0,6,0"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                BorderThickness="1"
                                Visibility="Collapsed">
                            <TextBox x:Name="NewTagInput"
                                     Width="120"
                                     FontSize="13"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     CaretBrush="{DynamicResource PrimaryTextBrush}"
                                     VerticalContentAlignment="Center"
                                     GotFocus="NewTagInput_GotFocus"
                                     LostFocus="NewTagInput_LostFocus"
                                     PreviewKeyDown="NewTagInput_PreviewKeyDown"
                                     KeyDown="NewTagInput_KeyDown" />
                        </Border>

                        <!-- 动态标签列表 -->
                        <ItemsControl x:Name="TagBar"
                                      ItemsSource="{Binding Tags}"
                                      PreviewMouseLeftButtonDown="TagBar_PreviewMouseLeftButtonDown"
                                      PreviewMouseMove="TagBar_PreviewMouseMove">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type sys:String}"
                                              xmlns:sys="clr-namespace:System;assembly=System.Runtime">
                                    <Border Margin="0,0,6,0"
                                            Padding="12,6"
                                            CornerRadius="6"
                                            Cursor="Hand"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            MouseLeftButtonUp="TagChip_Click"
                                            Tag="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       VerticalAlignment="Center" />
                                            <!-- 删除标签 -->
                                            <TextBlock Text="✕"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="5,0,0,0"
                                                       Opacity="0.5"
                                                       MouseLeftButtonUp="TagDelete_Click"
                                                       Tag="{Binding}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- 回收站与清空（行尾） -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding OpenRecycleBinCommand}"
                            ToolTip="回收站"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="10,0"
                            Cursor="Hand"
                            FontSize="14">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="♻" FontSize="16" />
                            <TextBlock Text="{Binding RecycleBinCount}" Margin="4,0,0,0" />
                        </StackPanel>
                    </Button>
                    <Button Content="清空"
                            Command="{Binding ClearAllCommand}"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="10,0"
                            Cursor="Hand"
                            FontSize="14" />
                </StackPanel>
            </Grid>

            <!-- ===== 横向滚动卡片列表（滑动分页加载） ===== -->
            <ScrollViewer x:Name="CardScrollViewer"
                          Grid.Row="1"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          PreviewMouseWheel="CardScrollViewer_PreviewMouseWheel"
                          PreviewMouseLeftButtonDown="CardScrollViewer_PreviewMouseLeftButtonDown"
                          PreviewMouseMove="CardScrollViewer_PreviewMouseMove"
                          PreviewMouseLeftButtonUp="CardScrollViewer_PreviewMouseLeftButtonUp"
                          ScrollChanged="CardScrollViewer_ScrollChanged"
                          Padding="10,0,10,12">
                <ItemsControl ItemsSource="{Binding FilteredItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ClipboardItem}">
                            <views:ClipboardItemCard
                                ItemSelected="Card_ItemSelected"
                                ItemDoubleClicked="Card_ItemDoubleClicked"
                                PinToggled="Card_PinToggled"
                                DeleteRequested="Card_DeleteRequested"
                                TagSetRequested="Card_TagSetRequested" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 空状态提示 -->
            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{Binding EmptyStateVisibility}">
                <TextBlock Text="📋"
                           FontSize="52"
                           HorizontalAlignment="Center"
                           Opacity="0.15" />
                <TextBlock Text="暂无剪贴板记录"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="15"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0" />
            </StackPanel>

            <!-- 拖拽幻影 Popup -->
            <Popup x:Name="DragGhostPopup"
                   AllowsTransparency="True"
                   Placement="Absolute"
                   IsHitTestVisible="False"
                   PopupAnimation="None"
                   Grid.RowSpan="99"
                   Visibility="Collapsed">
                <Border x:Name="DragGhostBorder"
                        Padding="12,6"
                        CornerRadius="6"
                        Background="{DynamicResource AccentBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1.1" ScaleY="1.1" />
                            <RotateTransform Angle="-3" />
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="6" Opacity="0.35" Color="#000000" />
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="DragGhostText"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="✕"
                                   FontSize="11"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="5,0,0,0"
                                   Opacity="0.6" />
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</Window>
