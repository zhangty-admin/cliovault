<Window x:Class="ClipVault.Views.RecycleBinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="回收站"
        Width="680" Height="460"
        MinWidth="520" MinHeight="340"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="回收站" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="删除的记录保留 7 天"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
            </StackPanel>
            <Button Grid.Column="1" Content="清空回收站" Click="Empty_Click"
                    Padding="12,7" VerticalAlignment="Center" />
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="6">
            <ListBox x:Name="RecycleList"
                     ItemsSource="{Binding RecycleBin}"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource PrimaryTextBrush}"
                     SelectionMode="Single">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="10,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Item.TypeIcon}" FontSize="18" />
                            <TextBlock Grid.Column="1" Text="{Binding Item.PreviewText}"
                                       TextTrimming="CharacterEllipsis" MaxHeight="42"
                                       VerticalAlignment="Center" Margin="8,0,12,0" />
                            <TextBlock Grid.Column="2" Text="{Binding DeletedTimeText}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="选择一条记录后可恢复或永久删除"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="永久删除" Click="Delete_Click"
                    Margin="0,0,8,0" Padding="14,8" />
            <Button Grid.Column="2" Content="恢复" Click="Restore_Click"
                    Padding="18,8" />
        </Grid>
    </Grid>
</Window>
