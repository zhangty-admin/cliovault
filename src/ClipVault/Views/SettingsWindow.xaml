<Window x:Class="ClipVault.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipVault 设置"
        Width="460"
        Height="430"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="ClipVault 设置"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,24" />

        <!-- 开机自启动 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="开机自启动"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       FontSize="14"
                       VerticalAlignment="Center"
                       Width="120" />
            <CheckBox IsChecked="{Binding AutoStartEnabled}"
                      VerticalAlignment="Center"
                      Cursor="Hand" />
        </StackPanel>

        <!-- 快捷键 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="唤出快捷键"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       FontSize="14"
                       VerticalAlignment="Center"
                       Width="120" />
            <Border x:Name="HotkeyBorder"
                    MinWidth="160"
                    Height="32"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,0,8,0"
                    Focusable="True"
                    GotFocus="HotkeyBorder_GotFocus"
                    LostFocus="HotkeyBorder_LostFocus"
                    MouseLeftButtonDown="HotkeyBorder_MouseLeftButtonDown">
                <TextBlock x:Name="HotkeyText"
                           Text="{Binding HotkeyDisplay}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
            <Button x:Name="ChangeHotkeyBtn"
                    Content="修改"
                    Width="60"
                    Height="32"
                    Cursor="Hand"
                    Click="ChangeHotkeyBtn_Click" />
            <Button x:Name="ResetHotkeyBtn"
                    Content="重置"
                    Width="60"
                    Height="32"
                    Margin="4,0,0,0"
                    Cursor="Hand"
                    Click="ResetHotkeyBtn_Click" />
        </StackPanel>

        <!-- 历史记录保留周期 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="自动清理"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       FontSize="14"
                       VerticalAlignment="Center"
                       Width="120" />
            <ComboBox ItemsSource="{Binding RetentionOptions}"
                      DisplayMemberPath="DisplayName"
                      SelectedItem="{Binding SelectedRetention}"
                      Width="200"
                      VerticalAlignment="Center"
                      Cursor="Hand" />
        </StackPanel>

        <!-- 清理预览 -->
        <Border Grid.Row="4"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="120,0,0,0"
                VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="{Binding CleanupPreview.SummaryText}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding CleanupPreview.DetailText}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="12"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- 版本信息 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal">
            <TextBlock Text="ClipVault v1.0.0"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontSize="12"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
