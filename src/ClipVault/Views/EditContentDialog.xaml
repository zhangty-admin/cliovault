<Window x:Class="ClipVault.Views.EditContentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑内容"
        Width="500"
        Height="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Border Background="{DynamicResource SurfaceBrush}"
            CornerRadius="12"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.5" Color="#000000" />
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="✏" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="编辑内容"
                               FontSize="16"
                               FontWeight="Medium"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Border Grid.Column="1"
                        Cursor="Hand"
                        MouseLeftButtonUp="CloseButton_Click"
                        Background="Transparent"
                        Padding="8,2"
                        CornerRadius="6">
                    <TextBlock Text="✕"
                               FontSize="14"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>

            <!-- 编辑区 -->
            <TextBox Grid.Row="1"
                     x:Name="ContentEditor"
                     FontSize="14"
                     Foreground="{DynamicResource PrimaryTextBrush}"
                     Background="{DynamicResource CardBackgroundBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1"
                     Padding="12,10"
                     CaretBrush="{DynamicResource PrimaryTextBrush}"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalContentAlignment="Top"
                     KeyDown="ContentEditor_KeyDown" />

            <!-- 底部按钮 -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="取消"
                        Width="80"
                        Height="34"
                        Margin="0,0,10,0"
                        Click="Cancel_Click"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" />

                <Border Width="80"
                        Height="34"
                        CornerRadius="5"
                        Cursor="Hand"
                        Background="{DynamicResource AccentBrush}"
                        MouseLeftButtonUp="Save_Click">
                    <TextBlock Text="保存"
                               FontSize="13"
                               FontWeight="Medium"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>
